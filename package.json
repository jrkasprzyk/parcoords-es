{
  "name": "parcoord-es",
  "version": "2.2.10",
  "description": "ES6 module of Parallel Coordinates, based on d3 v5 modules",
  "main": "dist/parcoords.js",
  "module": "dist/parcoords.esm.js",
  "jsnext:main": "dist/parcoords.esm.js",
  "style": "dist/parcoords.css",
  "scripts": {
    "_prebuild": "eslint src test",
    "build": "rollup -c",
    "dev": "rollup -c rollup.config.dev.js -w",
    "watch": "rollup -c -w",
    "pretest": "npm run build",
    "test:watch": "mocha --reporter min --watch",
    "test": "mocha",
    "test:cover": "babel-node ./node_modules/mocha/bin/_mocha",
    "prepare": "npm test",
    "format": "prettier --single-quote --trailing-comma es5 --write \"{src,__{tests,demo,dist}__}/**/*.{js,html}\""
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "d3-array": "^1.2.1",
    "d3-axis": "^1.0.8",
    "d3-brush": "^1.0.4",
    "d3-collection": "^1.0.4",
    "d3-dispatch": "^1.0.3",
    "d3-drag": "^1.2.1",
    "d3-interpolate": "^1.2.0",
    "d3-scale": "^2.1.0",
    "d3-selection": "^1.3.0",
    "d3-shape": "^1.2.0",
    "d3-transition": "^1.1.1",
    "requestanimationframe": "0.0.23",
    "sylvester-es6": "0.0.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.0",
    "@babel/core": "^7.25.0",
    "@babel/eslint-parser": "^7.25.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/register": "^7.25.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "eslint": "^8.57.0",
    "mocha": "^11.0.0",
    "prettier": "1.13.5",
    "rollup": "^4.20.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BigFatDog/parcoords-es.git"
  },
  "keywords": [
    "es6",
    "d3",
    "v4",
    "ParCoords",
    "visualization",
    "parallel coordinates"
  ],
  "author": {
    "name": "Xing Yun"
  },
  "license": "MIT",
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "bugs": {
    "url": "hhttps://github.com/BigFatDog/parcoords-es/issues"
  }
}
